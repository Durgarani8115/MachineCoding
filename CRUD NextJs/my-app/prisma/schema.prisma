
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url = env("DATABASE_URL") already in prisma.config.ts filepresent
}
model User{
  id String @id @default(cuid())
  name String
  email String @unique
  CreatedAt DateTime @default(now())
  UpdateAt DateTime @default(now()) @updatedAt
}
